
# -----------------------------------------------------------------------------
# KALSHI API CREDENTIALS (use .pem private key file)

KALSHI_API_KEY=your_kalshi_api_key_id_here
KALSHI_PRIVATE_KEY_PATH=./kalshi_private_key.pem
KALSHI_BASE_URL=https://api.elections.kalshi.com/trade-api/v2
# Optional: override WebSocket URL (default derived from KALSHI_BASE_URL)
# KALSHI_WS_URL=wss://api.calendar.kalshi.com/trade-api/ws/v2

# -----------------------------------------------------------------------------
# POLYMARKET API CREDENTIALS
# Market channel (default): no auth. User channel: set apiKey + secret + passphrase
# (from Polymarket SDK / createOrDeriveApiKey).

POLYMARKET_API_KEY=
POLYMARKET_SECRET=
POLYMARKET_PASSPHRASE=
POLYMARKET_BASE_URL=https://clob.polymarket.com


# -----------------------------------------------------------------------------
# LOGGING CONFIGURATION

LOG_LEVEL=INFO
LOG_FILE=./logs/trading_fund.log

# -----------------------------------------------------------------------------
# COPY TRADING STRATEGY SETTINGS

COPY_TRADING_MAX_POSITION_SIZE=1000.0
COPY_TRADING_MAX_TRADERS=10
COPY_TRADING_USE_KALSHI=false
# Trader discovery: low volume + high PnL (edge). Omit to accept all from leaderboard.
# COPY_TRADING_TRADER_MAX_VOLUME=50000
# COPY_TRADING_TRADER_MIN_PNL=1000
# COPY_TRADING_TRADER_MIN_PNL_PER_VOL=0.02
# COPY_TRADING_TRADER_TIME_PERIOD=WEEK

# -----------------------------------------------------------------------------
# MARKET MAKING STRATEGY SETTINGS

MARKET_MAKING_MAX_SPREAD=0.05
MARKET_MAKING_MIN_VOLUME=100.0
MARKET_MAKING_MAX_POSITION=5000.0
# Market discovery: high spread + liquidity. Used when running market_making strategy.
# MARKET_MAKING_DISCOVERY_MIN_LIQUIDITY=0
# MARKET_MAKING_DISCOVERY_MIN_SPREAD_PCT=0.005
# MARKET_MAKING_DISCOVERY_MIN_VOLUME_24H_KALSHI=0
# MARKET_MAKING_DISCOVERY_MAX_MARKETS=50

# -----------------------------------------------------------------------------
# ALT DATA STRATEGY SETTINGS
#
ALT_DATA_CONFIDENCE_THRESHOLD=0.7
TWITTER_API_KEY=your_twitter_api_key_here
TWITTER_API_SECRET=your_twitter_api_secret_here
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here

# -----------------------------------------------------------------------------
# SIMULATOR SETTINGS

SIMULATOR_SLIPPAGE=0.001
SIMULATOR_LATENCY_MS=50
SIMULATOR_USE_POLYMARKET=true
SIMULATOR_USE_KALSHI=true

# =============================================================================
# NOTES:
# =============================================================================
# 1. At minimum, you need KALSHI_API_KEY and KALSHI_PRIVATE_KEY_PATH (path to .pem file) to run strategies
# 2. POLYMARKET_API_KEY is optional - public data may not require authentication
# 3. Twitter credentials are only needed for the Alt Data strategy
# 4. All other settings have sensible defaults and are optional
# 5. Make sure to create the data/ and logs/ directories before running
# =============================================================================
